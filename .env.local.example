# ─── Supabase ───────────────────────────────────────────────
# Obtenelos en: https://supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxx...   # Settings → API → service_role (secret)

# ─── Resend ─────────────────────────────────────────────────
# Obtenelo en: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxx...

# Email desde el cual se envían los turnos (debe estar verificado en Resend)
FROM_EMAIL=turnos@tuclub.com
FROM_NAME=Club Tenis de Mesa

# ─── Anthropic ──────────────────────────────────────────────
# Obtenelo en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxx...

# ─── Admin ──────────────────────────────────────────────────
# Contraseña simple para proteger el panel de admin
ADMIN_PASSWORD=admin123
